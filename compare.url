javascript:(function(){const p="compare",parserOrigin="https://kgforth.github.io",parserUrl=parserOrigin+"/S10."+p+"/";const w=screen.availWidth, h=screen.availHeight, W=Math.floor(w*.92), H=Math.floor(h*.86);function getStudentId() {if (window.location.hostname !== 's10.run') return null;const urlMatch = window.location.search.match(/\?(\d+)/);if (urlMatch) return urlMatch[1] || urlMatch[0].replace(%27?%27, %27%27);const ampCookie = document.cookie.split(%27; %27).find(row => row.trim().startsWith(%27amp_%27));if (ampCookie) {try {const parts = ampCookie.split(%27=%27)[1].split(%27.%27);const decoded = atob(parts[1]);if (/^\d+$/.test(decoded)) return decoded;} catch(e) {}}return null;}const studentId = getStudentId();if (!studentId) { alert("Запустите над сайтом s10.run"); return; }const targetUrl = "https://s10.run/student?" + studentId + "&v2=1#/";const t = window.open(parserUrl, 'S10.'+p, %60width=${W},height=${H},top=${(h-H)/2},left=${(w-W)/2},resizable=yes,scrollbars=yes%60);function fetchAndSend(url){if(!url || url.includes('undefined')) return;fetch(url) .then(r => r.text()) .then(html => t.postMessage({type:"DATA_PAYLOAD", text:html, url:url}, parserOrigin)) .catch(err => t.postMessage({type:"FETCH_ERROR", error:err.message, url:url}, parserOrigin));} window.addEventListener("message", function(e){if(e.origin !== parserOrigin) return;if(e.data === "PARSER_READY"){fetchAndSend(targetUrl);} if(e.data.type === "START_FETCH"){fetchAndSend(targetUrl);} if(e.data.type === "FETCH_SPECIFIC_URL"){fetchAndSend(e.data.url);}});})();